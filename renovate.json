{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "Patch updates",
      "matchUpdateTypes": ["patch"]
    }
  ],
  "addLabels": ["dependency"],
  "assignees": ["@gjong"],
  "hostRules": [
    {
      "matchHost": "github.com",
      "token": "{{ secrets.GITHUB_REPO_ACCESS }}"
    }
  ]
}
